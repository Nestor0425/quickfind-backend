# =====================================================
# BACKEND ENVIRONMENT VARIABLES (API - NODE / EXPRESS)
# =====================================================
# ESTE ARCHIVO SÍ SE SUBE AL REPOSITORIO
# Es solo una plantilla de referencia SIN credenciales reales.
#
# Instrucciones:
# 1. Copiar a .env.development o .env.production
# 2. Reemplazar los valores según el entorno
# 3. NO subir archivos .env reales al repositorio

# =========================
# SERVER CONFIG
# =========================
# Puerto donde corre la API
PORT=3000

# Entorno de ejecución
# Valores: development | staging | production
NODE_ENV=development


# =========================
# AUTH & SECURITY (JWT)
# =========================
# Clave secreta para firmar tokens JWT
# NUNCA usar una clave débil en producción
JWT_SECRET=your_super_secure_jwt_secret


# =========================
# DATABASE CONFIG (POSTGRESQL / AWS RDS)
# =========================
# Host de la base de datos (AWS RDS endpoint)
DB_HOST=your-rds-endpoint.amazonaws.com

# Puerto de PostgreSQL (por defecto 5432)
DB_PORT=5432

# Nombre de la base de datos
DB_NAME=postgres

# Usuario de la base de datos
DB_USER=your_db_user

# Contraseña de la base de datos
DB_PASSWORD=your_db_password


# =========================
# DATABASE SSL CONFIGURATION
# =========================
# AWS RDS requiere SSL en la mayoría de configuraciones
DB_SSL=true

# En producción debe ser true
# En desarrollo puede ser false si hay errores de certificado
DB_SSL_REJECT_UNAUTHORIZED=true


# =========================
# EMAIL / SMTP CONFIG (NODEMAILER)
# =========================
# Usuario SMTP (Brevo, Gmail, etc.)
SMTP_USER=your_smtp_user

# Contraseña SMTP / API Key
SMTP_PASS=your_smtp_password

# Email remitente por defecto del sistema
SENDER_EMAIL=your_email@domain.com


# =========================
# SECURITY NOTE
# =========================
# ❌ NO incluir en este archivo:
# - Credenciales reales
# - Contraseñas de producción
# - Claves privadas
#
# Los valores reales deben configurarse en:
# .env.development (local)
# .env.production (servidor)
